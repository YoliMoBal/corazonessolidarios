---
const { title = "Corazones Solidarios Antequera" } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <link rel="stylesheet" href="/src/styles/global.css" />
  <title>{title}</title>
</head>
<body>

  <header>
    <div class="encabezado">
      <div class="logotipo">
        <a href="/">
          <img src="/img/logo.jpg" alt="Logo Corazones Solidarios" />
        </a>
      </div>
      <div class="texto">
        <h1>Corazones Solidarios Antequera</h1>
        <p>Bienvenidos a nuestra página web</p>
      </div>
      <div class="login">
        <a href="/admin" title="Acceso administración">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
            <path d="M16 11l4 4-4 4"/>
          </svg>
        </a>
      </div>
      <img class="marca-agua" src="/img/marca-agua.jpg" alt="" />
    </div>

    <input type="checkbox" id="menu-hamburguesa" class="menu-hamburguesa" />
    <label for="menu-hamburguesa" class="icono-hamburguesa">
      <span></span><span></span><span></span>
    </label>

    <nav>
      <ul class="menu_principal">
        <li>
          <a href="/">INICIO</a>
          <ul>
            <li><a href="/#noticias">Últimas Noticias</a></li>
            <li><a href="/historico">Histórico de Noticias</a></li>
            <li><a href="/galeria">Galería de Imágenes</a></li>
          </ul>
        </li>
        <li>
          <a href="/nosotros">NOSOTROS</a>
          <ul>
            <li><a href="/nosotros">Historia</a></li>
            <li><a href="/junta">Junta Directiva</a></li>
          </ul>
        </li>
        <li>
          <a href="/proyectos">PROYECTOS</a>
          <ul>
            <li><a href="/proyectos#cojines">Taller de Confección de Cojines</a></li>
            <li><a href="/proyectos#talleres">Talleres de Formación</a></li>
            <li><a href="/proyectos#promocion-salud">Promoción de Salud</a></li>
            <li><a href="/proyectos#mercadillos">Mercadillos Solidarios</a></li>
            <li><a href="/proyectos#corazon-de-oro">Premios Corazón de Oro</a></li>
            <li><a href="/proyectos#colaboracion">Colaboración Solidaria</a></li>
          </ul>
        </li>
        <li><a href="/galeria">GALERÍA</a></li>
        <li><a href="/junta">JUNTA DIRECTIVA</a></li>
        <li><a href="/contacto">CONTACTO</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>Contacto: corazonessolidariosantequera24@gmail.com</p>
    <p>&copy; 2025 Yolanda Moreno Balta · Todos los derechos reservados</p>
  </footer>

</body>
</html>