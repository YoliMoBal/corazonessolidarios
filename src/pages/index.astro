---
import Layout from '../layouts/Layout.astro';

const noticias = [
  {
    titulo: "Misión 112: enseñando a los más pequeños a salvar vidas",
    fecha: "Junio de 2026",
    categoria: "Formación",
    imagen: "/img/noticia_mision_112.jpg",
    texto: "Cerca de 250 niños y niñas del Colegio Nuestra Señora del Carmen recibieron formación en RCP y uso correcto del 112, de la mano de profesionales sanitarios y nuestro voluntariado."
  },
  {
    titulo: "Tejer como práctica de bienestar y cuidado personal",
    fecha: "2026",
    categoria: "Promoción de Salud",
    video: "https://www.facebook.com/plugins/video.php?height=314&href=https%3A%2F%2Fwww.facebook.com%2Freel%2F1672622833962275%2F&show_text=false&width=560&t=0",
    texto: "Recuperamos una práctica histórica de bienestar: tejer ayuda a calmar la mente. Animamos a todo el mundo a probarlo, sin edad ni condición."
  },
  {
    titulo: "Taller sobre Infecciones de Transmisión Sexual en el IES José María Fernández",
    fecha: "2026",
    categoria: "Promoción de Salud",
    imagen: "/img/noticia_its_instituto.jpg",
    texto: "El Dr. J. Manuel Muñoz Martínez impartió una charla cercana y participativa sobre ITS al alumnado de 3º de ESO."
  },
  {
    titulo: "Taller de Primeros Auxilios y RCP en la Agrupación Fotográfica Antequerana",
    fecha: "2026",
    categoria: "Talleres de Formación",
    imagen: "/img/noticia_rcp_afa.jpg",
    texto: "Profesionales voluntarios de Corazones Solidarios impartieron formación en primeros auxilios y RCP a los socios de la AFA."
  }
];
---

<Layout title="Inicio | Corazones Solidarios Antequera">

  <section class="hero">
    <div class="hero-fondo"></div>
    <div class="hero-contenido">
      <h2>Juntos hacemos posible<br/>una comunidad más solidaria</h2>
      <p>Formación en RCP, primeros auxilios, proyectos sociales y mucho más.<br/>Desde Antequera, cuidándonos entre todos.</p>
      <div class="hero-botones">
        <a href="/proyectos" class="btn-principal">Nuestros proyectos</a>
        <a href="#noticias" class="btn-secundario">Últimas noticias</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="num">+500</span><span class="label">Formados en RCP</span></div>
        <div class="stat"><span class="num">6</span><span class="label">Proyectos activos</span></div>
        <div class="stat"><span class="num">+10</span><span class="label">Años de voluntariado</span></div>
      </div>
    </div>
  </section>

  <section class="noticias-seccion" id="noticias">
    <div class="contenedor">
      <h2 class="seccion-titulo">Últimas Noticias</h2>
      <div class="grid-noticias">
        {noticias.map((n) => (
          <article class="tarjeta">
            <div class="tarjeta-img">
              {n.video ? (
                <iframe
                  src={n.video}
                  width="100%"
                  height="200"
                  style="border:none;overflow:hidden;"
                  scrolling="no"
                  frameborder="0"
                  allowfullscreen="true"
                  allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share">
                </iframe>
              ) : (
                <img src={n.imagen} alt={n.titulo} />
              )}
              <span class="categoria">{n.categoria}</span>
            </div>
            <div class="tarjeta-cuerpo">
              <p class="fecha">📅 {n.fecha}</p>
              <h3>{n.titulo}</h3>
              <p class="resumen">{n.texto}</p>
            </div>
          </article>
        ))}
      </div>
      <div class="btn-centro">
        <a href="/historico" class="btn-historico">Ver histórico de noticias →</a>
      </div>
    </div>
  </section>

  <section class="proyectos-seccion">
    <div class="contenedor">
      <h2 class="seccion-titulo">Nuestros Proyectos</h2>
      <div class="grid-proyectos">
        <a href="/proyectos#cojines" class="proyecto-card">
          <div class="proyecto-icono">🧵</div>
          <h3>Cojines Solidarios</h3>
          <p>Confección de cojines para mujeres con cáncer de mama.</p>
        </a>
        <a href="/proyectos#talleres" class="proyecto-card">
          <div class="proyecto-icono">💓</div>
          <h3>Talleres de Formación</h3>
          <p>RCP y primeros auxilios para saber actuar ante una emergencia.</p>
        </a>
        <a href="/proyectos#promocion-salud" class="proyecto-card">
          <div class="proyecto-icono">🩺</div>
          <h3>Promoción de Salud</h3>
          <p>Charlas de concienciación: ictus, donación, hábitos saludables.</p>
        </a>
        <a href="/proyectos#mercadillos" class="proyecto-card">
          <div class="proyecto-icono">🛍️</div>
          <h3>Mercadillos Solidarios</h3>
          <p>Recaudación de fondos con la Plataforma del Voluntariado.</p>
        </a>
        <a href="/proyectos#corazon-de-oro" class="proyecto-card">
          <div class="proyecto-icono">🏆</div>
          <h3>Premios Corazón de Oro</h3>
          <p>Reconocimiento anual a la labor solidaria en Antequera.</p>
        </a>
        <a href="/proyectos#colaboracion" class="proyecto-card">
          <div class="proyecto-icono">🤝</div>
          <h3>Colaboración Solidaria</h3>
          <p>Apoyo a personas vulnerables y a otras asociaciones.</p>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 3rem 2rem;
    text-align: center;
    color: white;
    overflow: hidden;
  }

  .hero-fondo {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(138,90,150,0.88) 0%, rgba(170,120,180,0.85) 60%, rgba(201,168,212,0.8) 100%),
      url('/img/mercadillo.jpg');
    background-size: cover;
    background-position: center;
    background-blend-mode: multiply;
    animation: kenburns 20s ease-in-out infinite alternate;
    z-index: 0;
  }

  @keyframes kenburns {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.15) translate(-1%, -1%); }
  }

  .hero-contenido { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; }

  .hero h2 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .hero-botones { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn-principal {
    background: white;
    color: #AA78B4;
    padding: 0.75rem 2rem;
    border-radius: 30px;
    font-weight: 700;
    text-decoration: none;
    font-size: 1rem;
    transition: transform 0.2s;
  }

  .btn-principal:hover { transform: translateY(-2px); }

  .btn-secundario {
    background: transparent;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 30px;
    font-weight: 700;
    text-decoration: none;
    font-size: 1rem;
    border: 2px solid rgba(255,255,255,0.6);
    transition: border-color 0.2s;
  }

  .btn-secundario:hover { border-color: white; }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.2);
    flex-wrap: wrap;
  }

  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat .num { font-size: 2rem; font-weight: 700; }
  .stat .label { font-size: 0.85rem; opacity: 0.8; }

  /* ── CONTENEDOR ── */
  .contenedor { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

  .seccion-titulo {
    font-size: 1.6rem;
    font-weight: 700;
    color: #AA78B4;
    text-align: center;
    margin-bottom: 2rem;
    position: relative;
  }

  .seccion-titulo::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: #AA78B4;
    margin: 0.5rem auto 0;
    border-radius: 2px;
  }

  /* ── NOTICIAS ── */
  .noticias-seccion { padding: 3rem 0; }

  .grid-noticias {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .tarjeta {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(170,120,180,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .tarjeta:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(170,120,180,0.15);
  }

  .tarjeta-img { position: relative; }

  .tarjeta-img img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .tarjeta-img iframe {
    width: 100%;
    height: 200px;
    display: block;
  }

  .categoria {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #AA78B4;
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 3px 12px;
    border-radius: 20px;
    z-index: 2;
  }

  .tarjeta-cuerpo { padding: 1.2rem; }

  .fecha { font-size: 0.82rem; color: #aaa; margin-bottom: 0.5rem; }

  .tarjeta-cuerpo h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #222;
    line-height: 1.4;
    margin-bottom: 0.6rem;
  }

  .resumen { font-size: 0.9rem; color: #666; line-height: 1.5; }

  .btn-centro { text-align: center; margin-top: 2.5rem; }

  .btn-historico {
    display: inline-block;
    color: #AA78B4;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border: 2px solid #AA78B4;
    padding: 0.7rem 2rem;
    border-radius: 30px;
    transition: background 0.2s, color 0.2s;
  }

  .btn-historico:hover {
    background: #AA78B4;
    color: white;
  }

  /* ── PROYECTOS ── */
  .proyectos-seccion {
    padding: 3rem 0;
    background: white;
  }

  .grid-proyectos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .proyecto-card {
    background: #F9F4FA;
    border: 1px solid #F0E4F5;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    transition: transform 0.2s;
    text-decoration: none;
    display: block;
  }

  .proyecto-card,
  .proyecto-card * {
    text-decoration: none;
  }

  .proyecto-card:hover { transform: translateY(-4px); }

  .proyecto-icono { font-size: 2.5rem; margin-bottom: 0.8rem; }

  .proyecto-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #AA78B4;
    margin-bottom: 0.5rem;
  }

  .proyecto-card p { font-size: 0.88rem; color: #666; line-height: 1.5; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .hero h2 { font-size: 1.5rem; }
    .grid-noticias { grid-template-columns: 1fr; }
    .grid-proyectos { grid-template-columns: repeat(2, 1fr); }
    .hero-stats { gap: 1.5rem; }
  }
</style>