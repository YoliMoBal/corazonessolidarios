---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Proyectos | Corazones Solidarios Antequera">

  <!-- Banner superior -->
  <section class="banner">
    <div class="banner-fondo"></div>
    <div class="banner-contenido">
      <h2>Nuestros Proyectos</h2>
      <p>Acciones que transforman vidas en Antequera</p>
    </div>
  </section>

  <!-- Taller de Confección de Cojines Solidarios -->
  <section class="bloque bloque-clara" id="cojines">
    <div class="contenedor">
      <div class="bloque-grid">
        <div class="bloque-imagen">
          <iframe 
            src="https://www.facebook.com/plugins/video.php?height=314&href=https%3A%2F%2Fwww.facebook.com%2Freel%2F4474895052742770%2F&show_text=false&width=560&t=0" 
            width="560" 
            height="314" 
            style="border:none;overflow:hidden;"
            scrolling="no" 
            frameborder="0" 
            allowfullscreen="true" 
            allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share">
          </iframe>
        </div>
        <div class="bloque-texto">
          <h3>Taller de Confección de Cojines Solidarios</h3>
          <p>Un grupo de voluntarias confecciona cojines en forma de corazón que se entregan a mujeres intervenidas por cáncer de mama, como símbolo de apoyo y cariño durante su recuperación.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Talleres de Formación -->
  <section class="bloque bloque-blanca" id="talleres">
    <div class="contenedor">
      <div class="bloque-grid invertido">
        <div class="bloque-texto">
            <h3>Talleres de Formación</h3>
            <p><strong>RCP y Primeros Auxilios</strong> — formación dirigida a toda la población, sin necesidad de conocimientos previos, para saber cómo actuar ante una parada cardiorrespiratoria u otra emergencia. A través de sesiones prácticas y teóricas, enseñamos técnicas de reanimación cardiopulmonar, uso de desfibriladores y primeros auxilios básicos, con el objetivo de que cualquier persona pueda intervenir con seguridad y confianza en los primeros minutos, que son decisivos para salvar una vida. Estos talleres se han impartido en centros educativos, asociaciones de vecinos y eventos públicos de Antequera, contribuyendo a convertir la ciudad en un entorno cada vez más cardioprotegido.</p>
        </div>
        <div class="bloque-imagen">
          <img src="/img/talleres_formacion.jpg" alt="Taller de formación en RCP y primeros auxilios" class="ampliable" />
        </div>
      </div>
    </div>
  </section>

  <!-- Promoción de Salud -->
  <section class="bloque bloque-clara" id="promocion-salud">
    <div class="contenedor">
      <div class="bloque-grid">
        <div class="bloque-imagen">
          <img src="/img/ictus.jpg" alt="Charla de promoción de la salud" class="ampliable" />
        </div>
        <div class="bloque-texto">
          <h3>Promoción de Salud</h3>
          <p>Charlas de concienciación y prevención dirigidas a toda la comunidad, abordando temas como:</p>
          <ul class="lista-proyecto">
            <li><strong>Ictus</strong> — prevención y detección temprana.</li>
            <li><strong>Donación de órganos</strong> — fomento de la cultura de la donación.</li>
            <li><strong>Enfermedades de transmisión sexual</strong> — información y prevención.</li>
            <li><strong>Hábitos de vida saludable</strong> — alimentación, ejercicio y bienestar.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Mercadillos Solidarios -->
  <section class="bloque bloque-blanca" id="mercadillos">
    <div class="contenedor">
      <div class="bloque-grid invertido">
        <div class="bloque-texto">
          <h3>Mercadillos Solidarios</h3>
          <p>Corazones Solidarios forma parte de la <strong>Plataforma del Voluntariado de Antequera</strong>, y a través de ella participa activamente en los mercadillos solidarios organizados en la ciudad, una forma de recaudar fondos y dar visibilidad a nuestra labor mientras compartimos espacio con otras asociaciones del territorio.</p>
        </div>
        <div class="bloque-imagen">
          <img src="/img/mercadillo.jpg" alt="Mercadillo Solidario en Antequera" class="ampliable" />
        </div>
      </div>
    </div>
  </section>

  <!-- Premios Corazón de Oro -->
  <section class="bloque bloque-clara" id="corazon-de-oro">
    <div class="contenedor">
      <div class="bloque-grid">
        <div class="bloque-imagen">
          <img src="/img/premios_corazon.jpg" alt="Entrega de los Premios Corazón de Oro" class="ampliable" />
        </div>
        <div class="bloque-texto">
          <span class="etiqueta">Reconocimiento</span>
          <h3>Premios Corazón de Oro</h3>
          <p>Cada año, Corazones Solidarios entrega los <strong>Premios Corazón de Oro</strong>, un reconocimiento a personas, colectivos y entidades que destacan por su labor solidaria y su compromiso con la comunidad de Antequera.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Colaboración Solidaria -->
  <section class="bloque bloque-blanca" id="colaboracion">
    <div class="contenedor">
      <div class="bloque-grid invertido">
        <div class="bloque-texto">
          <h3>Colaboración Solidaria</h3>
          <ul class="lista-proyecto">
            <li><strong>Apoyo a personas en situación de vulnerabilidad</strong> asociada a la pérdida de salud, a través de nuestra Farmacia Solidaria.</li>
            <li><strong>Apoyo a otras asociaciones</strong> de Antequera y su comarca, colaborando estrechamente con ellas en sus actividades y necesidades.</li>
          </ul>
        </div>
        <div class="bloque-imagen">
          <img src="/img/colaboracion_asociaciones.jpeg" alt="Colaboración solidaria" class="ampliable" />
        </div>
      </div>
    </div>
  </section>

  <!-- Colaboradores -->
  <section class="colaboradores">
    <div class="contenedor">
      <h3 class="seccion-titulo">Colaboradores</h3>
      <p class="colaboradores-texto">Gracias a las entidades, empresas e instituciones que nos apoyan a través de eventos, subvenciones y donaciones. Cada colaboración nos permite seguir creciendo y llegando a más personas.</p>
    </div>
  </section>

  <!-- Lightbox para ampliar imágenes -->
  <div class="lightbox" id="lightbox">
    <span class="lightbox-cerrar" id="lightbox-cerrar">&times;</span>
    <img src="" alt="" id="lightbox-img" />
  </div>

</Layout>

<style>
  /* ── BANNER ── */
  .banner {
    position: relative;
    padding: 4rem 2rem;
    text-align: center;
    color: white;
    overflow: hidden;
  }

  .banner-fondo {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(138,90,150,0.88) 0%, rgba(170,120,180,0.85) 60%, rgba(201,168,212,0.8) 100%),
      url('/img/mercadillo.jpg');
    background-size: cover;
    background-position: center;
    background-blend-mode: multiply;
    animation: kenburns 20s ease-in-out infinite alternate;
    z-index: 0;
  }

  @keyframes kenburns {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.15) translate(-1%, -1%); }
  }

  .banner-contenido { position: relative; z-index: 1; }

  .banner h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
  }

  .banner p {
    font-size: 1.2rem;
    opacity: 0.95;
  }

  /* ── CONTENEDOR ── */
  .contenedor {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── BLOQUES DE PROYECTO ── */
  .bloque {
    padding: 4rem 0;
    scroll-margin-top: 100px;
  }

  .bloque-clara { background: var(--color-muy-claro); }
  .bloque-blanca { background: white; }

  .bloque-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 3rem;
    align-items: center;
  }

  .bloque-grid.invertido {
    grid-template-columns: 1.3fr 1fr;
  }

  .bloque-grid.invertido .bloque-texto { order: 1; }
  .bloque-grid.invertido .bloque-imagen { order: 2; }

  .bloque-imagen {
    display: flex;
    justify-content: center;
  }

  .bloque-imagen img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(170,120,180,0.2);
    cursor: pointer;
    transition: transform 0.2s;
  }

  .bloque-imagen img:hover {
    transform: scale(1.02);
  }

  .bloque-imagen iframe {
    width: 100%;
    max-width: 560px;
    height: 314px;
    box-shadow: 0 8px 32px rgba(170,120,180,0.2);
    border-radius: 12px;
  }

  .etiqueta {
    display: inline-block;
    background: var(--color-muy-claro);
    color: var(--color-principal);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 1rem;
    letter-spacing: 0.5px;
  }

  .bloque-texto h3 {
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--color-principal);
    margin-bottom: 1.2rem;
  }

  .bloque-texto p {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    margin-bottom: 1rem;
    text-align: justify;
  }

  .lista-proyecto {
    list-style: none;
    padding: 0;
  }

  .lista-proyecto li {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    position: relative;
    text-align: justify;
  }

  .lista-proyecto li::before {
    content: '💜';
    position: absolute;
    left: 0;
    top: 0;
  }

  /* ── COLABORADORES ── */
  .colaboradores {
    padding: 4rem 0;
    background: var(--color-oscuro);
    text-align: center;
  }

  .seccion-titulo {
    font-size: 1.8rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
  }

  .colaboradores-texto {
    color: rgba(255,255,255,0.9);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto;
  }

  /* ── LIGHTBOX ── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 2000;
    justify-content: center;
    align-items: center;
  }

  .lightbox.activo {
    display: flex;
  }

  .lightbox img {
    max-width: 90%;
    max-height: 85%;
    border-radius: 8px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
  }

  .lightbox-cerrar {
    position: absolute;
    top: 20px;
    right: 30px;
    color: white;
    font-size: 2.5rem;
    cursor: pointer;
    line-height: 1;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .banner h2 { font-size: 1.8rem; }
    .bloque-grid,
    .bloque-grid.invertido {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .bloque-grid.invertido .bloque-texto,
    .bloque-grid.invertido .bloque-imagen {
      order: unset;
    }
    .bloque-imagen iframe {
      height: 250px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const cerrar = document.getElementById('lightbox-cerrar');
    const imagenes = document.querySelectorAll('.ampliable');

    imagenes.forEach((img) => {
      img.addEventListener('click', () => {
        lightboxImg.setAttribute('src', img.getAttribute('src'));
        lightboxImg.setAttribute('alt', img.getAttribute('alt'));
        lightbox.classList.add('activo');
      });
    });

    const cerrarLightbox = () => {
      lightbox.classList.remove('activo');
    };

    cerrar.addEventListener('click', cerrarLightbox);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) cerrarLightbox();
    });
  });
</script>